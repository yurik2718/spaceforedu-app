# Customer-facing brand data. Used by ApplicationHelper to render contacts
# and the company location across the site (auth footer, trust strip, etc.).
# Leaving any value unset is safe — the helpers fall back to a clearly-fake
# placeholder so the page still renders during local setup.

# Inbox shown in the auth footer.
SUPPORT_EMAIL=support@example.com

# WhatsApp number with country code; any human-readable spacing works.
# Helper strips non-digits to build the wa.me URL.
SUPPORT_WHATSAPP=+00 000 000 000

# Physical office location surfaced in the trust strip and footer copyright.
BRAND_LOCATION=City, Country
