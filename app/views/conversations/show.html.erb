<%= turbo_stream_from @conversation %>

<% content_for :main_class, "flex flex-col min-h-0 container mx-auto px-4 py-4" %>

<% hr = @conversation.homologation_request %>
<% back_path = Current.user.super_admin? ? admin_homologation_request_path(hr) : homologation_request_path(hr) %>

<div class="flex flex-col flex-1 min-h-0 max-w-2xl w-full mx-auto bg-canvas border border-hairline-soft rounded-lg overflow-hidden">

  <header class="flex items-center justify-between gap-3 border-b border-hairline-soft px-4 py-3 flex-shrink-0">
    <div class="flex items-center gap-1.5 min-w-0">
      <%= link_to back_path, class: "text-mute hover:text-ink shrink-0 p-1 -ml-1 rounded-md hover:bg-surface-soft", aria: { label: t("actions.back") } do %>
        <%= heroicon "chevron-left", options: { class: "w-5 h-5" } %>
      <% end %>
      <div class="min-w-0">
        <p class="font-semibold text-sm text-ink truncate leading-tight"><%= hr.subject %></p>
        <% if Current.user.super_admin? %>
          <p class="text-xs text-mute truncate"><%= @conversation.student.name %></p>
        <% end %>
      </div>
    </div>
    <span class="badge <%= status_badge_class(hr.status) %> shrink-0">
      <%= t("requests.status.#{hr.status}") %>
    </span>
  </header>

  <div id="messages"
       class="flex-1 min-h-0 overflow-y-auto p-4 flex flex-col gap-1"
       data-controller="scroll-to-bottom"
       data-current-user-id="<%= Current.user.id %>">
    <% if @messages.empty? %>
      <div class="flex-1 flex items-center justify-center">
        <p class="text-sm text-mute"><%= t("messages.empty") %></p>
      </div>
    <% else %>
      <% prev_date = nil %>
      <% @messages.each do |m| %>
        <% if prev_date != m.created_at.to_date %>
          <div class="divider text-xs text-mute my-2"><%= l m.created_at.to_date, format: :long %></div>
          <% prev_date = m.created_at.to_date %>
        <% end %>
        <%= render m %>
      <% end %>
    <% end %>
  </div>

  <%= render "messages/form", conversation: @conversation, message: @message %>

</div>
