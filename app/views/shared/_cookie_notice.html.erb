<div id="cookie-notice"
     data-controller="cookie-notice"
     class="fixed bottom-0 left-0 right-0 z-50 bg-ink text-white text-sm shadow-lg">
  <div class="container mx-auto px-4 py-3 flex items-center justify-between gap-4 flex-wrap">
    <p class="opacity-90">
      <%= t("cookie_notice.text") %>
      <%= link_to t("cookie_notice.privacy_link"), privacy_path, class: "underline opacity-75 hover:opacity-100" %>
    </p>
    <button data-action="cookie-notice#dismiss"
            class="shrink-0 bg-white text-ink text-xs font-semibold px-4 py-1.5 rounded-lg hover:bg-opacity-90 transition">
      <%= t("cookie_notice.dismiss") %>
    </button>
  </div>
</div>
