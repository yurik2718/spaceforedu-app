<%#
  Locals:
    status — String, one of HomologationRequest::STATUSES

  Maps every backend status to one of 5 visual milestones:
    draft → submitted → in_review → in_progress → resolved
  awaiting_reply collapses to in_review; awaiting_payment / payment_confirmed
  collapse to in_progress; closed renders as a dimmed terminal state.
%>
<%
  steps = %w[draft submitted in_review in_progress resolved]
  collapse = {
    "draft"             => "draft",
    "submitted"         => "submitted",
    "in_review"         => "in_review",
    "awaiting_reply"    => "in_review",
    "awaiting_payment"  => "in_progress",
    "payment_confirmed" => "in_progress",
    "in_progress"       => "in_progress",
    "resolved"          => "resolved",
    "closed"            => "resolved"
  }
  current     = collapse.fetch(status, "draft")
  current_idx = steps.index(current) || 0
  closed      = status == "closed"
%>

<ol class="flex items-center gap-0 w-full">
  <% steps.each_with_index do |step, i| %>
    <%
      done    = i <  current_idx
      active  = i == current_idx && !closed
      future  = i >  current_idx || closed && i > current_idx
    %>
    <li class="flex items-center <%= 'flex-1' unless i == steps.size - 1 %>">
      <div class="flex flex-col items-center gap-1.5 shrink-0">
        <span class="w-7 h-7 rounded-full inline-flex items-center justify-center text-xs font-semibold
                     <%= 'bg-primary text-on-primary' if active %>
                     <%= 'bg-ink text-on-dark'        if done %>
                     <%= 'bg-surface-card text-ash'   if future || (closed && i >= current_idx) %>">
          <% if done %>
            <%= heroicon "check", options: { class: "w-4 h-4", "aria-hidden": true } %>
          <% else %>
            <%= i + 1 %>
          <% end %>
        </span>
        <span class="text-xs font-medium whitespace-nowrap
                     <%= 'text-ink'  if active || done %>
                     <%= 'text-ash'  if future || (closed && i >= current_idx) %>">
          <%= t("requests.stepper.#{step}") %>
        </span>
      </div>

      <% unless i == steps.size - 1 %>
        <span class="flex-1 h-px mx-2 -mt-5
                     <%= 'bg-ink'           if done %>
                     <%= 'bg-hairline-soft' unless done %>"
              aria-hidden="true"></span>
      <% end %>
    </li>
  <% end %>
</ol>

<% if closed %>
  <p class="text-xs text-mute mt-3 text-center">
    <%= t("requests.status.closed") %>
  </p>
<% end %>
