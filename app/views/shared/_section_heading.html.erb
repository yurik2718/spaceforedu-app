<%#
  Locals:
    step        — Integer, step number (e.g. 1, 2, 3)
    title       — String
    description — String, optional subhead
%>
<header class="flex items-start gap-3">
  <span class="shrink-0 w-7 h-7 rounded-full bg-surface-card text-ink inline-flex items-center justify-center font-semibold text-sm">
    <%= step %>
  </span>
  <div class="min-w-0">
    <h2 class="text-base font-semibold text-ink leading-tight"><%= title %></h2>
    <% if local_assigns[:description].present? %>
      <p class="text-sm text-mute mt-0.5"><%= description %></p>
    <% end %>
  </div>
</header>
