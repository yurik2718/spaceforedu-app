<%#
  Locals:
    hr       — HomologationRequest
    editable — boolean. Admin = true (toggleable checkboxes); student = false (read-only with descriptions).
    terminal — boolean (default false). When true, mute the progress bar — the case is closed and "incomplete"
               progress is not actionable, just a snapshot.
%>
<%
  keys     = PipelineFlow.checklist_keys
  done     = keys.count { |k| hr.checklist_done?(k) }
  total    = keys.size
  terminal = local_assigns.fetch(:terminal, false)
  bar_class =
    if terminal
      "progress-neutral opacity-60"
    elsif done == total
      "progress-success"
    else
      "progress-primary"
    end
%>

<div class="card bg-canvas border border-hairline-soft <%= 'md:col-span-2' if editable %>">
  <div class="card-body" style="--card-body-pad: 1.5rem">
    <header class="flex items-start justify-between gap-2">
      <div>
        <h3 class="text-base font-semibold text-ink"><%= t("requests.sections.documents") %></h3>
        <% unless editable %>
          <p class="text-sm text-mute mt-0.5"><%= t("requests.sections.documents_subtitle") %></p>
        <% end %>
      </div>
      <span class="text-sm font-mono text-mute tabular-nums shrink-0 mt-0.5">
        <% if terminal %><span class="mr-1"><%= t("admin.requests.checklist.final_state") %></span><% end %>
        <%= done %>/<%= total %>
      </span>
    </header>

    <progress class="progress <%= bar_class %> w-full mt-3" value="<%= done %>" max="<%= total %>"></progress>

    <% if editable %>
      <ul class="mt-3 grid gap-1 sm:grid-cols-2">
        <% keys.each do |key| %>
          <li>
            <%= form_with url: admin_homologation_request_document_checklist_path(hr),
                          method: :patch,
                          scope: :document_checklist,
                          data: { controller: "auto-submit" },
                          class: "flex items-center gap-2 py-1" do |f| %>
              <%= f.hidden_field :key, value: key %>
              <%= f.hidden_field :value, value: (hr.checklist_done?(key) ? "0" : "1") %>
              <input type="checkbox" class="checkbox checkbox-sm"
                     <%= "checked" if hr.checklist_done?(key) %>
                     data-action="auto-submit#submit">
              <span class="text-sm <%= 'line-through text-ash' if hr.checklist_done?(key) %>">
                <%= t("requests.checklist.#{key}") %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <ul class="mt-4 space-y-3">
        <% keys.each do |key| %>
          <% is_done = hr.checklist_done?(key) %>
          <li class="flex items-start gap-2 text-sm">
            <% if is_done %>
              <%= heroicon "check-circle", variant: :solid, options: { class: "w-5 h-5 text-success shrink-0 mt-0.5", "aria-hidden": true } %>
            <% else %>
              <%= heroicon "clock", variant: :solid, options: { class: "w-5 h-5 text-ash shrink-0 mt-0.5", "aria-hidden": true } %>
            <% end %>
            <div class="flex-1">
              <p class="<%= is_done ? 'text-ash' : 'text-ink' %>"><%= t("requests.checklist.#{key}") %></p>
              <p class="text-xs text-mute leading-relaxed mt-0.5">
                <%= t("requests.checklist_descriptions.#{key}", default: "") %>
              </p>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>
