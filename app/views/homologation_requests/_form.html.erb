<%= form_with model: homologation_request, class: "card bg-base-100 shadow" do |f| %>
  <div class="card-body space-y-6">
    <%= f.hidden_field :service_type, value: homologation_request.service_type.presence || "homologation" %>

    <%# DIPLOMA %>
    <fieldset class="fieldset">
      <legend class="fieldset-legend"><%= t("requests.sections.diploma") %></legend>

      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <label class="label" for="<%= f.field_id(:university) %>"><%= t("requests.fields.university") %></label>
          <%= f.text_field :university,
                class: "input input-bordered w-full #{'input-error' if homologation_request.errors[:university].any?}" %>
          <% if homologation_request.errors[:university].any? %>
            <p class="label-text-alt text-error mt-1"><%= homologation_request.errors[:university].to_sentence %></p>
          <% end %>
        </div>

        <div>
          <label class="label" for="<%= f.field_id(:education_system) %>"><%= t("requests.fields.education_system") %></label>
          <%= f.text_field :education_system,
                class: "input input-bordered w-full #{'input-error' if homologation_request.errors[:education_system].any?}" %>
          <% if homologation_request.errors[:education_system].any? %>
            <p class="label-text-alt text-error mt-1"><%= homologation_request.errors[:education_system].to_sentence %></p>
          <% end %>
        </div>

        <div>
          <label class="label" for="<%= f.field_id(:year) %>"><%= t("requests.fields.year") %></label>
          <%= f.select :year,
                (1980..Date.today.year).to_a.reverse,
                { include_blank: true },
                class: "select select-bordered w-full" %>
        </div>

        <div>
          <label class="label" for="<%= f.field_id(:studies_finished) %>"><%= t("requests.fields.studies_finished") %></label>
          <%= f.select :studies_finished,
                [[t("requests.studies_finished.yes_label"), "yes"], [t("requests.studies_finished.no_label"), "no"]],
                { include_blank: true },
                class: "select select-bordered w-full" %>
        </div>
      </div>
    </fieldset>

    <div class="divider"></div>

    <%# LANGUAGE %>
    <fieldset class="fieldset">
      <legend class="fieldset-legend"><%= t("requests.sections.language") %></legend>

      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <label class="label" for="<%= f.field_id(:language_knowledge) %>"><%= t("requests.fields.language_knowledge") %></label>
          <%= f.select :language_knowledge,
                %w[A1 A2 B1 B2 C1 C2 native].map { |level| [t("requests.language_knowledge.#{level}"), level] },
                { include_blank: true },
                class: "select select-bordered w-full" %>
        </div>

        <div>
          <label class="label" for="<%= f.field_id(:language_certificate) %>"><%= t("requests.fields.language_certificate") %></label>
          <%= f.text_field :language_certificate, class: "input input-bordered w-full" %>
        </div>
      </div>
    </fieldset>

    <div class="divider"></div>

    <%# REQUEST %>
    <fieldset class="fieldset">
      <legend class="fieldset-legend"><%= t("requests.sections.request") %></legend>

      <label class="label" for="<%= f.field_id(:subject) %>"><%= t("requests.fields.subject") %></label>
      <%= f.text_field :subject,
            class: "input input-bordered w-full #{'input-error' if homologation_request.errors[:subject].any?}",
            required: true %>
      <% if homologation_request.errors[:subject].any? %>
        <p class="label-text-alt text-error mt-1"><%= homologation_request.errors[:subject].to_sentence %></p>
      <% end %>

      <label class="label mt-3" for="<%= f.field_id(:description) %>"><%= t("requests.fields.description") %></label>
      <%= f.text_area :description, class: "textarea textarea-bordered w-full", rows: 4 %>
    </fieldset>

    <% if homologation_request.new_record? %>
      <div class="divider"></div>

      <fieldset class="fieldset">
        <label class="label cursor-pointer justify-start gap-2">
          <%= check_box_tag "homologation_request[privacy_accepted]", "1", false, class: "checkbox" %>
          <span><%= t("requests.fields.privacy_accepted") %></span>
        </label>
      </fieldset>
    <% end %>

    <div class="card-actions justify-end pt-2">
      <%= link_to t("actions.cancel"), root_path, class: "btn btn-ghost" %>
      <%= f.submit t("actions.save"), class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
