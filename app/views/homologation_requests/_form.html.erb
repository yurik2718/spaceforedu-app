<%
  selected_plan = (homologation_request.plan_key.presence ||
                   params[:plan].presence_in(Plan::KEYS) ||
                   "basico")
  plan_locked   = !homologation_request.new_record? && homologation_request.status != "draft"
%>
<%= form_with model: homologation_request, class: "card bg-canvas border border-hairline-soft" do |f| %>
  <div class="flex flex-col gap-8 p-6 sm:p-8">

    <%# 1 — PLAN %>
    <section class="space-y-5">
      <%= render "shared/section_heading",
            step: 1,
            title: t("requests.sections.plan"),
            description: t("requests.sections.plan_description") %>

      <% if plan_locked %>
        <%= f.hidden_field :plan_key %>
        <% plan = Plan.find(homologation_request.plan_key) %>
        <div class="rounded-2xl border border-hairline-soft bg-surface-card p-5 flex items-center justify-between gap-4">
          <div>
            <p class="text-sm text-mute"><%= t("requests.payment.your_plan") %></p>
            <p class="text-lg font-semibold text-ink mt-0.5"><%= plan.title %></p>
          </div>
          <p class="text-2xl font-semibold tabular-nums text-ink">
            <%= format_eur plan.amount %>
          </p>
        </div>
      <% else %>
        <div class="grid gap-3 md:grid-cols-3">
          <% Plan.all.each do |plan| %>
            <% checked = plan.key == selected_plan %>
            <label class="relative cursor-pointer">
              <%= f.radio_button :plan_key, plan.key, checked: checked, class: "peer sr-only", required: true %>
              <div class="rounded-2xl border-2 border-hairline-soft bg-canvas p-5 h-full flex flex-col gap-3 transition
                          peer-checked:border-primary peer-checked:bg-primary/5
                          peer-focus-visible:ring-2 peer-focus-visible:ring-primary/30 peer-focus-visible:ring-offset-2
                          hover:border-ink/30">
                <div>
                  <h3 class="text-base font-semibold text-ink"><%= plan.title %></h3>
                  <% if plan.short_desc.present? %>
                    <p class="text-xs text-mute mt-1 leading-snug"><%= plan.short_desc %></p>
                  <% end %>
                </div>
                <div class="flex items-baseline gap-1 mt-auto">
                  <span class="text-3xl font-semibold tabular-nums text-ink">
                    <%= format_eur plan.amount %>
                  </span>
                </div>
              </div>
            </label>
          <% end %>
        </div>
        <p class="text-sm text-mute mt-3">
          <%= link_to t("plans.compare_link"), t("plans.compare_url"),
                target: "_blank", rel: "noopener",
                class: "underline-offset-2 hover:underline hover:text-ink" %>
        </p>
      <% end %>
    </section>

    <hr class="border-hairline-soft">

    <%# 2 — DIPLOMA %>
    <section class="space-y-5">
      <%= render "shared/section_heading",
            step: 2,
            title: t("requests.sections.diploma"),
            description: t("requests.sections.diploma_description") %>


      <div class="grid md:grid-cols-2 gap-x-5 gap-y-4">
        <%= render "shared/field",
              form: f, name: :university,
              required: true,
              placeholder: t("requests.placeholders.university"),
              hint: t("requests.hints.university") %>

        <%= render "shared/field",
              form: f, name: :education_system,
              placeholder: t("requests.placeholders.education_system"),
              hint: t("requests.hints.education_system") %>

        <%= render "shared/field",
              form: f, name: :year,
              type: :select,
              choices: (1980..Date.today.year).to_a.reverse,
              hint: t("requests.hints.year") %>

        <%= render "shared/field",
              form: f, name: :studies_finished,
              type: :select,
              choices: [[t("requests.studies_finished.yes_label"), "yes"],
                        [t("requests.studies_finished.no_label"),  "no"]],
              hint: t("requests.hints.studies_finished") %>
      </div>
    </section>

    <hr class="border-hairline-soft">

    <%# 3 — LANGUAGE %>
    <section class="space-y-5">
      <%= render "shared/section_heading",
            step: 3,
            title: t("requests.sections.language"),
            description: t("requests.sections.language_description") %>

      <div class="grid md:grid-cols-2 gap-x-5 gap-y-4">
        <%= render "shared/field",
              form: f, name: :language_knowledge,
              type: :select,
              choices: %w[A1 A2 B1 B2 C1 C2 native].map { |level| [t("requests.language_knowledge.#{level}"), level] },
              hint: t("requests.hints.language_knowledge") %>

        <%= render "shared/field",
              form: f, name: :language_certificate,
              placeholder: t("requests.placeholders.language_certificate"),
              hint: t("requests.hints.language_certificate") %>
      </div>
    </section>

    <hr class="border-hairline-soft">

    <%# 4 — REQUEST %>
    <section class="space-y-5">
      <%= render "shared/section_heading",
            step: 4,
            title: t("requests.sections.request"),
            description: t("requests.sections.request_description") %>

      <div class="space-y-4">
        <%= render "shared/field",
              form: f, name: :subject,
              required: true,
              placeholder: t("requests.placeholders.subject"),
              hint: t("requests.hints.subject") %>

        <%= render "shared/field",
              form: f, name: :description,
              type: :textarea, rows: 5,
              placeholder: t("requests.placeholders.description"),
              hint: t("requests.hints.description") %>
      </div>
    </section>

    <% if homologation_request.new_record? %>
      <hr class="border-hairline-soft">

      <label class="flex items-start gap-3 cursor-pointer">
        <%= check_box_tag "homologation_request[privacy_accepted]", "1", false,
              class: "checkbox mt-0.5 shrink-0", required: true %>
        <span class="text-sm text-body leading-relaxed">
          <%= t("requests.fields.privacy_accepted_html", url: privacy_path).html_safe %>
        </span>
      </label>
    <% end %>

    <div class="flex items-center justify-end gap-3 pt-2">
      <%= link_to t("actions.cancel"), root_path,
            class: "text-sm font-medium text-mute hover:text-ink transition-colors" %>
      <%= f.submit (homologation_request.new_record? ? t("requests.save_draft") : t("actions.save")),
            class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
