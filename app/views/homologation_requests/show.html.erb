<% content_for :title, @homologation_request.subject %>

<% hr = @homologation_request %>
<% can_edit = policy(hr).update? && hr.editable? %>

<%= turbo_stream_from hr %>

<%# ── Header ────────────────────────────────────────── %>
<header class="mb-6 flex items-start justify-between gap-4 flex-wrap">
  <div class="min-w-0 flex-1">
    <h1 class="t-heading-xl break-words"><%= hr.subject %></h1>
    <div class="flex items-center gap-2 mt-2 text-sm text-mute flex-wrap">
      <time datetime="<%= hr.created_at.iso8601 %>">
        <%= t("requests.timeline.created_at") %> <%= l(hr.created_at, format: :long) %>
      </time>
      <% if hr.updated_at > hr.created_at + 1.minute %>
        <span aria-hidden="true">·</span>
        <time datetime="<%= hr.updated_at.iso8601 %>">
          <%= t("requests.timeline.updated_at") %> <%= l(hr.updated_at, format: :short) %>
        </time>
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-2 shrink-0">
    <% if hr.conversation %>
      <% unread = hr.conversation.unread_for?(Current.user) %>
      <%= link_to conversation_path(hr.conversation), class: "btn btn-secondary btn-sm gap-1.5" do %>
        <%= heroicon "chat-bubble-left-right", options: { class: "w-4 h-4", "aria-hidden": true } %>
        <span><%= t("requests.actions.open_chat") %></span>
        <% if unread %>
          <span class="text-primary text-base leading-none ml-1" aria-label="unread">•</span>
        <% end %>
      <% end %>
    <% end %>

    <% if can_edit %>
      <%= link_to t("actions.edit"), edit_homologation_request_path(hr), class: "btn btn-ghost btn-sm" %>
    <% end %>

    <%= render "homologation_requests/submit_action", hr: hr %>
  </div>
</header>

<%# ── Status stepper ─────────────────────────────────── %>
<div class="card bg-canvas border border-hairline-soft mb-5">
  <div class="card-body" style="--card-body-pad: 1.5rem">
    <%= render "shared/status_stepper", status: hr.status %>
  </div>
</div>

<%# ── What's next ────────────────────────────────────── %>
<%
  next_step_key =
    case hr.status
    when "draft"
      hr.ready_to_submit? ? :ready : :missing_app
    when "submitted"                              then :submitted
    when "in_review"                              then :in_review
    when "awaiting_reply"                         then :awaiting_reply
    when "awaiting_payment"                       then :awaiting_payment
    when "payment_confirmed", "in_progress"       then :in_progress
    when "resolved"                               then :resolved
    when "closed"                                 then :closed
    when "declined"                               then :declined
    end
%>

<div class="card bg-surface-card mb-6 p-5 flex items-start gap-4">
  <span class="shrink-0 w-9 h-9 rounded-full bg-surface-card text-mute inline-flex items-center justify-center" aria-hidden="true">
    <%= heroicon "information-circle", variant: :solid, options: { class: "w-6 h-6" } %>
  </span>
  <div class="min-w-0">
    <h2 class="text-base font-semibold text-ink"><%= t("requests.next_step.heading") %></h2>
    <p class="text-sm text-body mt-1 leading-relaxed"><%= t("requests.next_step.#{next_step_key}") %></p>
  </div>
</div>

<%# ── Declined: pull the manager's reason inline ───────── %>
<% if hr.declined? && hr.conversation %>
  <% manager_message = hr.conversation.messages.where.not(user_id: hr.user_id).order(created_at: :desc).first %>
  <div class="card bg-canvas border border-error/40 mb-6">
    <div class="card-body" style="--card-body-pad: 1.5rem">
      <header class="flex items-center gap-2 text-error">
        <%= heroicon "x-circle", variant: :solid, options: { class: "w-5 h-5", "aria-hidden": true } %>
        <h2 class="text-base font-semibold"><%= t("requests.declined_card.heading") %></h2>
      </header>
      <% if manager_message %>
        <p class="text-sm text-body mt-3 whitespace-pre-line leading-relaxed"><%= manager_message.body %></p>
      <% else %>
        <p class="text-sm text-mute mt-3"><%= t("requests.declined_card.empty") %></p>
      <% end %>
      <%= link_to conversation_path(hr.conversation),
            class: "btn btn-secondary btn-sm gap-1.5 mt-4" do %>
        <%= heroicon "chat-bubble-left-right", options: { class: "w-4 h-4", "aria-hidden": true } %>
        <span><%= t("requests.declined_card.open_chat") %></span>
      <% end %>
    </div>
  </div>
<% end %>

<%# ── Documents (the main work) ──────────────────────── %>
<%= render "homologation_requests/documents", hr: hr, can_edit: can_edit %>

<%# ── Info + checklist ───────────────────────────────── %>
<div class="grid gap-6 md:grid-cols-2 mt-6">

  <%# REQUEST INFO %>
  <%
    info_pairs = [
      [t("requests.fields.university"),       hr.university.presence],
      [t("requests.fields.education_system"), hr.education_system.presence],
      [t("requests.fields.year"),             hr.year],
      [t("requests.fields.studies_finished"), hr.studies_finished.present? ? t("requests.studies_finished.#{hr.studies_finished}_label", default: nil) : nil],
      [t("requests.fields.language_knowledge"), hr.language_knowledge.present? ? t("requests.language_knowledge.#{hr.language_knowledge}", default: nil) : nil],
      [t("requests.fields.language_certificate"), hr.language_certificate.presence]
    ].reject { |_, v| v.blank? }
  %>
  <div class="card bg-canvas border border-hairline-soft">
    <div class="card-body" style="--card-body-pad: 1.5rem">
      <header class="flex items-center justify-between gap-2">
        <h3 class="text-base font-semibold text-ink"><%= t("requests.sections.info") %></h3>
        <% if can_edit %>
          <%= link_to t("actions.edit"),
                edit_homologation_request_path(hr),
                class: "text-sm font-medium text-mute hover:text-ink underline-offset-2 hover:underline" %>
        <% end %>
      </header>

      <% if info_pairs.any? %>
        <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2.5 text-sm mt-4">
          <% info_pairs.each do |label, value| %>
            <dt class="text-mute"><%= label %></dt>
            <dd class="text-ink"><%= value %></dd>
          <% end %>
        </dl>
      <% else %>
        <p class="text-sm text-mute mt-4">—</p>
      <% end %>

      <% if hr.description.present? %>
        <hr class="border-hairline-soft my-4">
        <p class="text-sm whitespace-pre-line leading-relaxed text-body"><%= hr.description %></p>
      <% end %>
    </div>
  </div>

  <%# CHECKLIST %>
  <%= render "shared/checklist", hr: hr, editable: false %>

  <%# PAYMENT — always visible: plan + price are known from creation %>
  <% unless hr.declined? %>
    <% plan = hr.plan %>
    <% can_pay = policy(hr).checkout? %>
    <% paid    = hr.payment_confirmed_at.present? %>
    <div class="card bg-canvas border <%= can_pay ? 'border-primary ring-1 ring-primary/30' : 'border-hairline-soft' %> md:col-span-2">
      <div class="card-body" style="--card-body-pad: 1.5rem">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="min-w-0">
            <p class="text-xs uppercase tracking-wide text-mute font-semibold"><%= t("requests.payment.your_plan") %></p>
            <h3 class="text-xl font-semibold text-ink mt-1"><%= plan.title %></h3>
            <p class="text-sm text-mute mt-0.5"><%= plan.short_desc %></p>
          </div>
          <div class="text-right">
            <p class="text-3xl font-semibold tabular-nums text-ink">
              <%= format_eur plan.amount %>
            </p>
            <% if paid %>
              <p class="text-xs text-success mt-1">
                ✓ <%= t("requests.payment.confirmed_at") %> <%= l hr.payment_confirmed_at, format: :short %>
              </p>
            <% end %>
          </div>
        </div>

        <% if can_pay %>
          <div class="mt-5">
            <%= button_to t("requests.payment.pay_now", amount: format_eur(plan.amount)),
                  homologation_request_checkout_path(hr),
                  method: :post,
                  class: "btn btn-primary w-full text-base h-12" %>
            <p class="text-xs text-mute mt-2 text-center"><%= t("requests.payment.pay_subtitle") %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
