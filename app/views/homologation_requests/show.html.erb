<% content_for :title, @homologation_request.subject %>

<% hr = @homologation_request %>

<%= turbo_stream_from hr %>

<%= render "shared/page_header",
      title: hr.subject,
      actions: capture {
        concat content_tag(:span, t("requests.status.#{hr.status}"), class: "badge badge-lg #{status_badge_class(hr.status)}")
        if hr.conversation
          unread_count = hr.conversation.unread_for?(Current.user) ? 1 : 0
          concat(link_to(conversation_path(hr.conversation), class: "btn btn-secondary btn-sm gap-1.5") do
            chat_icon = content_tag(:svg, '<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a8 8 0 01-11.5 7.2L4 21l1.8-5.5A8 8 0 1121 12z"/>'.html_safe,
              viewBox: "0 0 24 24", class: "w-4 h-4", fill: "none", stroke: "currentColor", "stroke-width": 2, "aria-hidden": true)
            label = content_tag(:span, t("requests.actions.open_chat"))
            badge = unread_count.positive? ? content_tag(:span, "•", class: "text-primary text-base leading-none ml-1") : "".html_safe
            chat_icon + label + badge
          end)
        end
        if policy(hr).update? && HomologationRequestsController::EDITABLE_STATUSES.include?(hr.status)
          concat link_to(t("actions.edit"), edit_homologation_request_path(hr), class: "btn btn-ghost btn-sm")
        end
        if policy(hr).submit? && hr.status == "draft"
          concat button_to(t("requests.actions.submit"), homologation_request_submission_path(hr), method: :post, class: "btn btn-primary btn-sm")
        end
      } %>

<div class="grid gap-6 md:grid-cols-2">

  <%# REQUEST INFO %>
  <div class="card bg-white shadow">
    <div class="card-body">
      <h3 class="card-title text-base"><%= t("requests.sections.info") %></h3>

      <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm mt-2">
        <dt class="opacity-60"><%= t("requests.fields.university") %></dt>
        <dd><%= hr.university.presence || "—" %></dd>

        <dt class="opacity-60"><%= t("requests.fields.education_system") %></dt>
        <dd><%= hr.education_system.presence || "—" %></dd>

        <dt class="opacity-60"><%= t("requests.fields.year") %></dt>
        <dd><%= hr.year || "—" %></dd>

        <dt class="opacity-60"><%= t("requests.fields.studies_finished") %></dt>
        <dd>
          <% if hr.studies_finished.present? %>
            <%= t("requests.studies_finished.#{hr.studies_finished}_label", default: hr.studies_finished) %>
          <% else %>—<% end %>
        </dd>

        <dt class="opacity-60"><%= t("requests.fields.language_knowledge") %></dt>
        <dd>
          <% if hr.language_knowledge.present? %>
            <%= t("requests.language_knowledge.#{hr.language_knowledge}", default: hr.language_knowledge) %>
          <% else %>—<% end %>
        </dd>

        <dt class="opacity-60"><%= t("requests.fields.language_certificate") %></dt>
        <dd><%= hr.language_certificate.presence || "—" %></dd>
      </dl>

      <% if hr.description.present? %>
        <div class="divider my-2"></div>
        <p class="text-sm whitespace-pre-line leading-relaxed opacity-80"><%= hr.description %></p>
      <% end %>
    </div>
  </div>

  <%# CHECKLIST — read-only with progress %>
  <% checklist_keys  = PipelineFlow.checklist_keys %>
  <% checklist_done  = checklist_keys.count { |k| hr.checklist_done?(k) } %>
  <% checklist_total = checklist_keys.size %>
  <div class="card bg-white shadow">
    <div class="card-body">
      <header class="flex items-center justify-between gap-2">
        <h3 class="card-title text-base"><%= t("requests.sections.documents") %></h3>
        <span class="text-sm font-mono opacity-70"><%= checklist_done %>/<%= checklist_total %></span>
      </header>

      <progress class="progress <%= checklist_done == checklist_total ? 'progress-success' : 'progress-primary' %> w-full"
                value="<%= checklist_done %>" max="<%= checklist_total %>"></progress>

      <ul class="mt-2 space-y-1">
        <% checklist_keys.each do |key| %>
          <li class="flex items-center gap-2">
            <input type="checkbox" class="checkbox checkbox-sm" disabled
                   <%= "checked" if hr.checklist_done?(key) %>>
            <span class="text-sm <%= 'line-through opacity-50' if hr.checklist_done?(key) %>">
              <%= t("requests.checklist.#{key}") %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <%# DOCUMENTS — student uploads %>
  <% can_edit = policy(hr).update? && HomologationRequestsController::EDITABLE_STATUSES.include?(hr.status) %>
  <%= render "homologation_requests/documents", hr: hr, can_edit: can_edit %>

  <%# PAYMENT — only when relevant %>
  <% if hr.payment_amount.present? || hr.status == "awaiting_payment" %>
    <div class="card bg-white shadow md:col-span-2">
      <div class="card-body">
        <h3 class="card-title text-base"><%= t("requests.sections.payment") %></h3>

        <% if hr.payment_amount.present? %>
          <p class="text-2xl font-semibold mt-1"><%= number_to_currency hr.payment_amount %></p>
        <% else %>
          <p class="opacity-60"><%= t("requests.payment.not_set") %></p>
        <% end %>

        <% if policy(hr).checkout? %>
          <%= button_to t("requests.payment.pay_now"),
                homologation_request_checkout_path(hr),
                method: :post,
                class: "btn btn-primary mt-4 w-full" %>
        <% end %>

        <% if hr.payment_confirmed_at %>
          <p class="text-xs opacity-60 mt-1">
            <%= t("requests.payment.confirmed_at") %>:
            <%= l hr.payment_confirmed_at, format: :long %>
          </p>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
