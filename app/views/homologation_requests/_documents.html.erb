<%# Locals:
      hr               — HomologationRequest
      can_edit         — boolean. When true, empty slots are upload forms.
      intro            — optional String, copy under the section title.
      show_empty_slots — optional. Defaults to can_edit. When true, render
                         placeholder slots for kinds without an uploaded file.
                         Admin views pass true so the grid stays informative
                         ("what's still missing") even though admin can't upload. %>
<%
  intro_text        = local_assigns.fetch(:intro, t("requests.attachments.intro"))
  show_empty_slots  = local_assigns.fetch(:show_empty_slots, can_edit)
  documents_by_kind = hr.request_documents.includes(file_attachment: :blob).index_by(&:kind)
  ordered_kinds     = RequestDocument::REQUIRED_KINDS + (RequestDocument::KINDS - RequestDocument::REQUIRED_KINDS)
  kinds_to_render   = show_empty_slots ? ordered_kinds : ordered_kinds.select { |k| documents_by_kind[k] }
%>
<% if kinds_to_render.any? %>
  <%= turbo_frame_tag dom_id(hr, :documents) do %>
    <div class="card bg-canvas border border-hairline-soft md:col-span-2">
      <div class="card-body">
        <header class="flex items-center justify-between gap-3">
          <div>
            <h3 class="card-title text-base"><%= t("requests.sections.attachments") %></h3>
            <% if intro_text.present? %>
              <p class="text-sm text-mute mt-1"><%= intro_text %></p>
            <% end %>
          </div>
          <% if can_edit %>
            <%= render "homologation_requests/documents_progress", hr: hr %>
          <% end %>
        </header>

        <div class="mt-4 grid sm:grid-cols-2 gap-2">
          <% kinds_to_render.each do |kind| %>
            <%= render "homologation_requests/document_slot",
                  hr:       hr,
                  kind:     kind,
                  document: documents_by_kind[kind],
                  can_edit: can_edit %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
