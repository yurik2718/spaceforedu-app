<% if current_user.nil? %>

  <div class="hero min-h-[60vh]">
    <div class="hero-content text-center">
      <div class="max-w-lg">
        <h1 class="text-4xl font-bold">Homologación de títulos universitarios</h1>
        <p class="py-6 text-base-content/70">
          Gestionamos el reconocimiento de tu título en España de forma eficiente, transparente y con seguimiento en tiempo real.
        </p>
        <div class="flex gap-3 justify-center">
          <%= link_to t("nav.sign_in"), new_session_path, class: "btn btn-primary" %>
          <%= link_to t("registrations.submit"), new_registration_path, class: "btn btn-ghost" %>
        </div>
      </div>
    </div>
  </div>

<% else %>

  <%= render "shared/page_header", title: t("nav.dashboard") %>

  <% if @requests.empty? %>
    <div class="card bg-base-100 shadow">
      <div class="card-body items-center text-center py-16">
        <p class="text-base-content/50 text-lg"><%= t("requests.empty") %></p>
      </div>
    </div>
  <% else %>
    <div class="card bg-base-100 shadow">
      <div class="overflow-x-auto">
        <table class="table">
          <tbody>
            <% @requests.each do |r| %>
              <tr class="hover">
                <td>
                  <p class="font-medium"><%= r.subject %></p>
                  <p class="text-sm text-base-content/50"><%= r.university %></p>
                </td>
                <td>
                  <span class="badge <%= status_badge_class(r.status) %>">
                    <%= t("requests.status.#{r.status}") %>
                  </span>
                </td>
                <td class="text-right">
                  <% if r.conversation %>
                    <%= link_to t("nav.conversations"), conversation_path(r.conversation), class: "btn btn-sm btn-ghost" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

<% end %>
