<% if current_user.nil? %>

  <div class="hero min-h-[60vh]">
    <div class="hero-content text-center">
      <div class="max-w-lg">
        <h1 class="text-4xl font-bold"><%= t("home.hero.title") %></h1>
        <p class="py-6 opacity-70"><%= t("home.hero.subtitle") %></p>
        <div class="flex gap-3 justify-center">
          <%= link_to t("nav.sign_in"), new_session_path, class: "btn btn-primary" %>
          <%= link_to t("registrations.submit"), new_registration_path, class: "btn btn-ghost" %>
        </div>
      </div>
    </div>
  </div>

<% else %>

  <%= render "shared/page_header",
        title: t("nav.dashboard"),
        actions: capture {
          concat link_to(t("requests.actions.new"), new_homologation_request_path, class: "btn btn-primary btn-sm")
        } %>

  <% if @requests.empty? %>
    <div class="card bg-base-100 shadow">
      <div class="card-body items-center text-center py-16 gap-4">
        <p class="opacity-60"><%= t("requests.empty") %></p>
        <%= link_to t("requests.actions.new"), new_homologation_request_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% else %>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <% @requests.each do |r| %>
        <%= link_to homologation_request_path(r), class: "card bg-base-100 shadow hover:shadow-md transition", id: dom_id(r) do %>
          <div class="card-body">
            <header class="flex items-start justify-between gap-2">
              <h3 class="font-semibold truncate" title="<%= r.subject %>"><%= r.subject %></h3>
              <span class="badge <%= status_badge_class(r.status) %> shrink-0">
                <%= t("requests.status.#{r.status}") %>
              </span>
            </header>

            <% if r.university.present? %>
              <p class="text-sm opacity-60 truncate"><%= r.university %></p>
            <% end %>

            <time class="text-xs opacity-50 mt-2"><%= l r.updated_at, format: :short %></time>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

<% end %>
