<% content_for :title, t("privacy.page_title") %>

<div class="max-w-3xl mx-auto py-8 space-y-8">

  <div>
    <h1 class="text-3xl font-bold text-ink"><%= t("privacy.page_title") %></h1>
    <p class="text-sm text-mute mt-1"><%= t("privacy.last_updated") %></p>
  </div>

  <%# 1. Responsable / Data Controller %>
  <section class="space-y-2">
    <h2 class="text-xl font-semibold text-ink"><%= t("privacy.controller.title") %></h2>
    <p class="text-body leading-relaxed">
      <%= t("privacy.controller.body_html",
            company: brand_name,
            address: brand_address,
            cif:     brand_cif,
            email:   privacy_contact_email) %>
    </p>
  </section>

  <%# 2. Datos recopilados / Data Collected %>
  <section class="space-y-4">
    <h2 class="text-xl font-semibold text-ink"><%= t("privacy.data_collected.title") %></h2>

    <div class="overflow-x-auto rounded-xl border border-hairline-soft">
      <table class="w-full text-sm">
        <thead class="bg-surface-soft text-mute text-xs uppercase tracking-wide">
          <tr>
            <th class="px-4 py-3 text-left font-medium w-1/4"><%= t("privacy.data_collected.items_label") %></th>
            <th class="px-4 py-3 text-left font-medium w-2/5"><%= t("privacy.data_collected.purpose_label") %></th>
            <th class="px-4 py-3 text-left font-medium"><%= t("privacy.data_collected.basis_label") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-hairline-soft">
          <% t("privacy.data_collected.categories").each do |_key, cat| %>
            <tr class="bg-white">
              <td class="px-4 py-3 font-medium text-ink align-top"><%= cat[:title] %></td>
              <td class="px-4 py-3 text-body align-top"><%= cat[:items] %><br><span class="text-mute text-xs"><%= cat[:purpose] %></span></td>
              <td class="px-4 py-3 text-mute align-top text-xs"><%= cat[:basis] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <%# 3. Retención / Retention %>
  <section class="space-y-3">
    <h2 class="text-xl font-semibold text-ink"><%= t("privacy.retention.title") %></h2>
    <p class="text-body leading-relaxed"><%= t("privacy.retention.intro") %></p>
    <ul class="space-y-1 text-sm text-body list-disc list-inside">
      <% t("privacy.retention.rows").each_value do |row| %>
        <li><%= row %></li>
      <% end %>
    </ul>
  </section>

  <%# 4. Destinatarios / Recipients %>
  <section class="space-y-3">
    <h2 class="text-xl font-semibold text-ink"><%= t("privacy.recipients.title") %></h2>
    <p class="text-body leading-relaxed"><%= t("privacy.recipients.intro") %></p>

    <div class="space-y-3">
      <div class="rounded-xl border border-hairline-soft bg-white p-4">
        <p class="font-semibold text-ink text-sm"><%= t("privacy.recipients.stripe.name") %></p>
        <p class="text-sm text-body mt-1">
          <%= t("privacy.recipients.stripe.role") %>
          <%= link_to t("privacy.recipients.stripe.dpa_link"),
                      "https://#{t('privacy.recipients.stripe.dpa_link')}",
                      target: "_blank", rel: "noopener", class: "link" %>.
        </p>
      </div>
      <div class="rounded-xl border border-hairline-soft bg-white p-4">
        <p class="font-semibold text-ink text-sm"><%= t("privacy.recipients.hosting.name") %></p>
        <p class="text-sm text-body mt-1"><%= t("privacy.recipients.hosting.role") %></p>
      </div>
    </div>
  </section>

  <%# 5. Derechos / Rights %>
  <section class="space-y-3">
    <h2 class="text-xl font-semibold text-ink"><%= t("privacy.rights.title") %></h2>
    <p class="text-body leading-relaxed"><%= t("privacy.rights.intro") %></p>
    <ul class="space-y-1 text-sm text-body list-disc list-inside">
      <% t("privacy.rights.items").each_value do |item| %>
        <li><%= item %></li>
      <% end %>
    </ul>
  </section>

  <%# 6. Cómo ejercer / How to exercise %>
  <section class="space-y-2">
    <h2 class="text-xl font-semibold text-ink"><%= t("privacy.how_to_exercise.title") %></h2>
    <p class="text-body leading-relaxed">
      <%= t("privacy.how_to_exercise.body_html",
            profile_url: authenticated? ? profile_path : new_registration_path,
            email:       privacy_contact_email) %>
    </p>
  </section>

  <%# 7. Cookies %>
  <section class="space-y-2">
    <h2 class="text-xl font-semibold text-ink"><%= t("privacy.cookies.title") %></h2>
    <p class="text-body leading-relaxed"><%= t("privacy.cookies.body") %></p>
  </section>

  <%# 8. AEPD / Complaints %>
  <section class="space-y-2">
    <h2 class="text-xl font-semibold text-ink"><%= t("privacy.complaints.title") %></h2>
    <p class="text-body leading-relaxed"><%= t("privacy.complaints.body_html") %></p>
  </section>

</div>
