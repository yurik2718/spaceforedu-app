<% content_for :title, t("auth.password_update_title") %>

<%= render "shared/page_header", title: t("auth.password_update_title") %>

<%= form_with url: password_path(params[:token]), method: :put, class: "card bg-white shadow max-w-md mx-auto" do |f| %>
  <div class="card-body">
    <fieldset class="fieldset">
      <label class="label" for="<%= f.field_id(:password) %>"><%= t("auth.new_password") %></label>
      <%= f.password_field :password,
            required: true,
            autofocus: true,
            autocomplete: "new-password",
            maxlength: 72,
            class: "input input-bordered w-full" %>
    </fieldset>

    <fieldset class="fieldset">
      <label class="label" for="<%= f.field_id(:password_confirmation) %>"><%= t("auth.repeat_password") %></label>
      <%= f.password_field :password_confirmation,
            required: true,
            autocomplete: "new-password",
            maxlength: 72,
            class: "input input-bordered w-full" %>
    </fieldset>

    <div class="card-actions justify-end pt-2">
      <%= f.submit t("actions.save"), class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
