<% content_for :title, t("auth.password_update_title") %>

<h1 class="font-display font-bold text-4xl text-ink leading-[1.1] tracking-tight"><%= t("auth.password_update_title") %></h1>

<%= form_with url: password_path(params[:token]), method: :put, class: "space-y-5" do |f| %>
  <div>
    <label class="label" for="<%= f.field_id(:password) %>"><%= t("auth.new_password") %></label>
    <%= f.password_field :password,
          required: true,
          autofocus: true,
          autocomplete: "new-password",
          maxlength: 72,
          placeholder: "••••••••",
          class: "input w-full" %>
  </div>

  <div>
    <label class="label" for="<%= f.field_id(:password_confirmation) %>"><%= t("auth.repeat_password") %></label>
    <%= f.password_field :password_confirmation,
          required: true,
          autocomplete: "new-password",
          maxlength: 72,
          placeholder: "••••••••",
          class: "input w-full" %>
  </div>

  <div class="pt-1">
    <%= f.submit t("actions.save"), class: "btn btn-primary w-full h-12 text-base" %>
  </div>
<% end %>
