<% content_for :title, t("nav.notifications") %>

<%= turbo_stream_from current_user %>

<%= render "shared/page_header",
      title: t("nav.notifications"),
      actions: capture {
        if @unread_count > 0
          concat button_to(t("notifications.mark_all_read"), read_all_notifications_path,
                   method: :post,
                   class:  "btn btn-secondary btn-sm")
        end
      } %>

<% if @groups.any? %>
  <div id="notifications" class="space-y-2">
    <% @groups.each do |group| %>
      <%= render "notification", notification: group.first, count: group.size %>
    <% end %>
  </div>

  <% if @pagy.pages > 1 %>
    <%
      page_btn = ->(label, page, position) {
        rounding = { left: "rounded-r-none", center: "rounded-none", right: "rounded-l-none" }.fetch(position)
        if page
          link_to label, url_for(page: page), class: "btn btn-sm btn-secondary #{rounding}"
        else
          tag.span label, class: "btn btn-sm btn-disabled #{rounding}"
        end
      }
    %>
    <div class="flex justify-center mt-6">
      <div class="flex">
        <%= page_btn.("«", (@pagy.page - 1 if @pagy.page > 1), :left) %>
        <span class="btn btn-sm btn-secondary rounded-none pointer-events-none">
          <%= @pagy.page %> / <%= @pagy.pages %>
        </span>
        <%= page_btn.("»", (@pagy.page + 1 if @pagy.page < @pagy.pages), :right) %>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="card bg-canvas border border-hairline-soft">
    <div class="card-body items-center text-center py-16 gap-2">
      <h2 class="text-lg font-semibold"><%= t("notifications.empty_heading") %></h2>
      <p class="text-mute"><%= t("notifications.empty") %></p>
    </div>
  </div>
<% end %>
