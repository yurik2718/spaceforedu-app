<% content_for :title, t("nav.notifications") %>

<%= render "shared/page_header", title: t("nav.notifications") %>

<% if @notifications.any? %>
  <div id="notifications" class="space-y-2">
    <%= render @notifications %>
  </div>

  <% if @pagy.pages > 1 %>
    <%
      page_btn = ->(label, page, position) {
        rounding = { left: "rounded-r-none", center: "rounded-none", right: "rounded-l-none" }.fetch(position)
        if page
          link_to label, url_for(page: page), class: "btn btn-sm btn-secondary #{rounding}"
        else
          tag.span label, class: "btn btn-sm btn-disabled #{rounding}"
        end
      }
    %>
    <div class="flex justify-center mt-6">
      <div class="flex">
        <%= page_btn.("«", (@pagy.page - 1 if @pagy.page > 1), :left) %>
        <span class="btn btn-sm btn-secondary rounded-none pointer-events-none">
          <%= @pagy.page %> / <%= @pagy.pages %>
        </span>
        <%= page_btn.("»", (@pagy.page + 1 if @pagy.page < @pagy.pages), :right) %>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="card bg-white shadow">
    <div class="card-body items-center text-center py-16">
      <p class="opacity-60"><%= t("notifications.empty") %></p>
    </div>
  </div>
<% end %>
