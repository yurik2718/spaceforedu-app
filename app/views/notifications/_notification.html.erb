<div id="<%= dom_id(notification) %>"
     class="card card-compact bg-white shadow-sm border-l-4 <%= notification.read_at? ? 'border-gray-200 opacity-70' : 'border-primary' %>">
  <div class="card-body">
    <header class="flex items-start justify-between gap-3">
      <h4 class="font-semibold text-sm"><%= notification.title %></h4>
      <time class="text-xs opacity-60 shrink-0">
        <% if notification.created_at.today? %>
          <%= time_ago_in_words(notification.created_at) %>
        <% else %>
          <%= l notification.created_at, format: :short %>
        <% end %>
      </time>
    </header>
    <p class="text-sm opacity-80"><%= notification.body %></p>
  </div>
</div>
