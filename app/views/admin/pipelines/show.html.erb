<%= render "shared/page_header", title: t("nav.pipeline") %>

<div class="stats stats-vertical sm:stats-horizontal w-full bg-canvas mb-6">
  <div class="stat">
    <div class="stat-title"><%= t("pipeline.active") %></div>
    <div class="stat-value tabular-nums"><%= @stats[:active] %></div>
  </div>
  <div class="stat">
    <div class="stat-title"><%= t("pipeline.revenue") %></div>
    <div class="stat-value tabular-nums"><%= number_to_currency @stats[:revenue] %></div>
  </div>
  <div class="stat">
    <div class="stat-title"><%= t("pipeline.stages.completado") %></div>
    <div class="stat-value tabular-nums"><%= @grouped[PipelineFlow::TERMINAL_STAGE].size %></div>
  </div>
</div>

<%# KANBAN — sequential stages, horizontal scroll %>
<div class="flex gap-4 overflow-x-auto pb-4 -mx-4 px-4 snap-x">
  <% @kanban_stages.each do |stage| %>
    <% records = @grouped[stage] %>
    <section class="card bg-canvas border border-hairline-soft w-64 shrink-0 snap-start" data-stage="<%= stage %>">
      <header class="flex items-start justify-between gap-2 px-4 py-3 border-b border-hairline-soft min-h-14">
        <h3 class="font-semibold text-[11px] uppercase tracking-[0.06em] text-mute leading-tight"><%= t("pipeline.stages.#{stage}") %></h3>
        <span class="badge badge-neutral badge-sm shrink-0"><%= records.size %></span>
      </header>

      <div class="p-3 min-h-32">
        <% if records.empty? %>
          <p class="text-xs text-ash text-center py-6">
            <%= t("pipeline.empty") %>
          </p>
        <% else %>
          <div class="flex flex-col gap-2">
            <% records.each do |request_record| %>
              <%= link_to admin_homologation_request_path(request_record),
                    id: dom_id(request_record),
                    class: "block rounded-xl border border-hairline-soft bg-canvas px-3 py-2 hover:border-ink hover:bg-surface-soft transition no-underline" do %>
                <p class="font-medium text-sm text-ink truncate"><%= request_record.user.name %></p>
                <p class="text-xs text-mute truncate mt-0.5"><%= request_record.subject %></p>
                <p class="text-[11px] text-ash truncate mt-1.5 font-mono tabular-nums">
                  <%= request_record.plan.title %>
                  <span aria-hidden="true">·</span>
                  <%= t("requests.timeline.updated_at") %> <%= time_ago_in_words(request_record.updated_at) %>
                </p>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

<%# BRANCH + TERMINAL stages — outcomes after kanban %>
<% cotejo_stages, terminal_stages = @horizontal_stages.partition { |s| PipelineFlow::COTEJO_STAGES.include?(s) } %>

<% if cotejo_stages.any? %>
  <div class="grid gap-4 md:grid-cols-2 mt-6">
    <% cotejo_stages.each do |stage| %>
      <%= render "stage_section", stage: stage, records: @grouped[stage], accent: "info" %>
    <% end %>
  </div>
<% end %>

<% terminal_stages.each do |stage| %>
  <div class="mt-4">
    <%= render "stage_section", stage: stage, records: @grouped[stage], accent: "success" %>
  </div>
<% end %>
