<%= render "shared/page_header", title: t("nav.pipeline") %>

<div class="stats shadow mb-6">
  <div class="stat">
    <div class="stat-title">Active</div>
    <div class="stat-value"><%= @stats[:active] %></div>
  </div>
  <div class="stat">
    <div class="stat-title">Revenue</div>
    <div class="stat-value"><%= number_to_currency @stats[:revenue] %></div>
  </div>
</div>

<div class="grid grid-flow-col auto-cols-fr gap-4">
  <% @kanban_stages.each do |stage| %>
    <section class="card bg-base-100 shadow" data-stage="<%= stage %>">
      <div class="card-body">
        <h3 class="card-title"><%= t("pipeline.stages.#{stage}") %></h3>
        <% @grouped[stage].each do |request_record| %>
          <article class="card bg-base-200 mt-2" id="<%= dom_id(request_record) %>">
            <div class="card-body p-3">
              <p class="font-medium"><%= request_record.user.name %></p>
              <p class="text-sm opacity-70"><%= request_record.subject %></p>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

<div class="grid grid-flow-col auto-cols-fr gap-4 mt-6">
  <% @horizontal_stages.each do |stage| %>
    <section class="card bg-base-100 shadow" data-stage="<%= stage %>">
      <div class="card-body">
        <h3 class="card-title"><%= t("pipeline.stages.#{stage}") %></h3>
        <% @grouped[stage].each do |request_record| %>
          <p><%= request_record.subject %></p>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
