<%= render "shared/page_header", title: t("nav.pipeline") %>

<div class="stats stats-vertical sm:stats-horizontal shadow mb-6">
  <div class="stat py-3">
    <div class="stat-title"><%= t("pipeline.active") %></div>
    <div class="stat-value text-2xl text-primary"><%= @stats[:active] %></div>
  </div>
  <div class="stat py-3">
    <div class="stat-title"><%= t("pipeline.revenue") %></div>
    <div class="stat-value text-2xl"><%= number_to_currency @stats[:revenue] %></div>
  </div>
</div>

<div class="flex gap-4 overflow-x-auto pb-4 snap-x">
  <% @kanban_stages.each do |stage| %>
    <% records = @grouped[stage] %>
    <section class="card bg-base-200 w-72 shrink-0 snap-start" data-stage="<%= stage %>">
      <div class="card-body p-4">
        <header class="flex items-center justify-between gap-2 mb-3">
          <h3 class="font-semibold text-sm uppercase tracking-wide opacity-70 truncate"><%= t("pipeline.stages.#{stage}") %></h3>
          <span class="badge badge-neutral badge-sm shrink-0"><%= records.size %></span>
        </header>

        <% if records.empty? %>
          <p class="text-center text-xs opacity-30 py-2">—</p>
        <% else %>
          <div class="flex flex-col gap-2">
            <% records.each do |request_record| %>
              <%= link_to admin_homologation_request_path(request_record), class: "block" do %>
                <article class="card card-compact bg-base-100 shadow-sm hover:shadow-md transition" id="<%= dom_id(request_record) %>">
                  <div class="card-body">
                    <p class="font-medium text-sm truncate" title="<%= request_record.user.name %>"><%= request_record.user.name %></p>
                    <p class="text-xs opacity-70 line-clamp-2"><%= request_record.subject %></p>
                  </div>
                </article>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
  <% @horizontal_stages.each do |stage| %>
    <% records = @grouped[stage] %>
    <section class="card bg-base-100 border border-base-300" data-stage="<%= stage %>">
      <header class="flex items-center justify-between gap-2 px-4 py-3 border-b border-base-300">
        <h3 class="font-semibold text-sm uppercase tracking-wide opacity-70 truncate"><%= t("pipeline.stages.#{stage}") %></h3>
        <span class="badge badge-ghost badge-sm shrink-0"><%= records.size %></span>
      </header>

      <% if records.empty? %>
        <p class="text-center text-xs opacity-30 py-3">—</p>
      <% else %>
        <ul class="divide-y divide-base-200">
          <% records.each do |request_record| %>
            <li>
              <%= link_to request_record.subject,
                    admin_homologation_request_path(request_record),
                    class: "block px-4 py-2 text-sm hover:bg-base-200 truncate" %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </section>
  <% end %>
</div>
