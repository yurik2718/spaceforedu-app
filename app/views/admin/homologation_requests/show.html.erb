<% content_for :title, @homologation_request.subject %>

<% hr      = @homologation_request %>
<% student = hr.user %>

<%= render "shared/page_header",
      title: hr.subject,
      actions: capture {
        if hr.conversation
          concat link_to(t("admin.requests.actions.open_chat"), conversation_path(hr.conversation), class: "btn btn-sm")
        else
          concat button_to(t("admin.requests.actions.start_chat"), admin_homologation_request_conversation_path(hr), method: :post, class: "btn btn-sm")
        end
        concat link_to(t("admin.requests.actions.download_archive"), admin_homologation_request_archive_path(hr), class: "btn btn-sm")
        concat link_to(t("actions.back"), admin_pipeline_path, class: "btn btn-ghost btn-sm")
      } %>

<div class="grid gap-6 md:grid-cols-2">

  <%# STATUS + PIPELINE — primary control surface, full width %>
  <div class="card bg-white border border-gray-200 md:col-span-2">
    <div class="card-body gap-6 md:flex-row md:divide-x md:divide-gray-200">

      <%# Status %>
      <section class="md:flex-1 md:pr-6 space-y-3">
        <header class="flex items-center justify-between gap-3">
          <div class="min-w-0">
            <h3 class="text-sm font-semibold uppercase tracking-wide opacity-60"><%= t("admin.requests.sections.status") %></h3>
            <% if hr.status_changed_at %>
              <p class="text-xs opacity-60 mt-1">
                <%= l hr.status_changed_at, format: :long %>
                <% if hr.status_changer %>· <%= hr.status_changer.email_address %><% end %>
              </p>
            <% end %>
          </div>
          <span class="badge badge-lg <%= status_badge_class(hr.status) %> shrink-0">
            <%= t("requests.status.#{hr.status}") %>
          </span>
        </header>

        <%= form_with url: admin_homologation_request_status_transitions_path(hr),
                      scope: :status_transition,
                      class: "flex gap-2" do |f| %>
          <%= f.select :status,
                HomologationRequest::STATUSES.map { |s| [t("requests.status.#{s}"), s] },
                { selected: hr.status },
                class: "select select-bordered select-sm flex-1" %>
          <%= f.submit t("admin.requests.actions.change_status"), class: "btn btn-primary btn-sm" %>
        <% end %>
      </section>

      <%# Pipeline %>
      <section class="md:flex-1 md:pl-6 space-y-3">
        <header class="flex items-center justify-between gap-3">
          <div class="min-w-0">
            <h3 class="text-sm font-semibold uppercase tracking-wide opacity-60"><%= t("admin.requests.sections.pipeline") %></h3>
            <% if hr.pipeline_stage && hr.pipeline_changed_at %>
              <p class="text-xs opacity-60 mt-1">
                <%= l hr.pipeline_changed_at, format: :long %>
                <% if hr.pipeline_changer %>· <%= hr.pipeline_changer.email_address %><% end %>
              </p>
            <% end %>
          </div>
          <% if hr.pipeline_stage %>
            <span class="badge badge-lg badge-primary shrink-0">
              <%= t("pipeline.stages.#{hr.pipeline_stage}") %>
            </span>
          <% end %>
        </header>

        <% if hr.pipeline_stage %>
          <div class="flex gap-2 justify-end" data-controller="dialog">
            <button type="button" data-action="dialog#open" class="btn btn-ghost btn-sm">
              ← <%= t("admin.requests.actions.retreat") %>
            </button>
            <%= button_to t("admin.requests.actions.advance") + " →",
                  admin_homologation_request_pipeline_advance_path(hr),
                  method: :post,
                  class: "btn btn-primary btn-sm" %>

            <dialog data-dialog-target="dialog" class="modal">
              <div class="modal-box">
                <form method="dialog">
                  <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
                </form>
                <h3 class="font-bold text-lg mb-4"><%= t("admin.requests.actions.retreat_modal") %></h3>
                <%= form_with url: admin_homologation_request_pipeline_retreat_path(hr),
                              scope: :pipeline_retreat do |f| %>
                  <fieldset class="fieldset">
                    <label class="label" for="<%= f.field_id(:reason) %>"><%= t("admin.requests.labels.retreat_reason") %></label>
                    <%= f.text_area :reason, class: "textarea textarea-bordered w-full", rows: 3, required: true %>
                  </fieldset>
                  <div class="modal-action">
                    <%= f.submit t("admin.requests.actions.retreat"), class: "btn btn-warning" %>
                  </div>
                <% end %>
              </div>
              <form method="dialog" class="modal-backdrop"><button>close</button></form>
            </dialog>
          </div>
        <% else %>
          <p class="opacity-60 text-sm"><%= t("requests.payment.not_set") %></p>
        <% end %>
      </section>
    </div>
  </div>

  <%# STUDENT %>
  <div class="card bg-white border border-gray-200">
    <div class="card-body">
      <h3 class="text-sm font-semibold uppercase tracking-wide opacity-60"><%= t("admin.requests.sections.student") %></h3>

      <div class="flex items-center gap-3 mt-2">
        <%= render "shared/avatar", user: student, size: :md %>
        <div class="min-w-0">
          <p class="font-semibold truncate text-ink"><%= student.name %></p>
          <p class="text-sm text-mute truncate"><%= student.email_address %></p>
        </div>
      </div>

      <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-1 text-sm mt-3 pt-3 border-t border-gray-200">
        <dt class="opacity-60"><%= t("profile.fields.country") %></dt>
        <dd><%= student.country.presence || "—" %></dd>
        <dt class="opacity-60"><%= t("profile.fields.phone") %></dt>
        <dd><%= student.phone.presence || "—" %></dd>
      </dl>
    </div>
  </div>

  <%# PAYMENT %>
  <div class="card bg-white border border-gray-200">
    <div class="card-body">
      <header class="flex items-center justify-between">
        <h3 class="text-sm font-semibold uppercase tracking-wide opacity-60"><%= t("admin.requests.sections.payment") %></h3>
        <% if hr.payment_confirmed_at %>
          <span class="badge badge-success badge-sm gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <%= t("admin.requests.labels.confirmed_at") %>
          </span>
        <% end %>
      </header>

      <% if hr.payment_amount.present? %>
        <p class="text-3xl font-semibold mt-2"><%= number_to_currency hr.payment_amount %></p>
      <% else %>
        <p class="opacity-60 mt-2"><%= t("requests.payment.not_set") %></p>
      <% end %>

      <% if hr.payment_confirmed_at %>
        <p class="text-xs opacity-60 mt-1">
          <%= l hr.payment_confirmed_at, format: :long %>
          <% if hr.payment_confirmer %>· <%= hr.payment_confirmer.email_address %><% end %>
        </p>
      <% end %>

      <% if hr.status == "awaiting_payment" %>
        <%= form_with url: admin_homologation_request_payment_confirmation_path(hr),
                      scope: :payment_confirmation,
                      class: "flex gap-2 mt-4" do |f| %>
          <% if hr.payment_amount.blank? %>
            <%= f.number_field :payment_amount,
                  step: 0.01,
                  placeholder: t("requests.fields.payment_amount"),
                  class: "input input-bordered input-sm flex-1" %>
          <% end %>
          <%= f.submit t("admin.requests.actions.confirm_payment"), class: "btn btn-success btn-sm" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# DOCUMENTS — uploaded by student, downloadable here %>
  <%= render "homologation_requests/documents", hr: hr, can_edit: false %>

  <%# CHECKLIST — full width, with progress %>
  <% checklist_keys  = PipelineFlow.checklist_keys %>
  <% checklist_done  = checklist_keys.count { |k| hr.checklist_done?(k) } %>
  <% checklist_total = checklist_keys.size %>
  <div class="card bg-white border border-gray-200 md:col-span-2">
    <div class="card-body">
      <header class="flex items-center justify-between gap-2">
        <h3 class="text-sm font-semibold uppercase tracking-wide opacity-60"><%= t("admin.requests.sections.checklist") %></h3>
        <span class="text-sm font-mono opacity-70"><%= checklist_done %>/<%= checklist_total %></span>
      </header>

      <progress class="progress <%= checklist_done == checklist_total ? 'progress-success' : 'progress-primary' %> w-full mt-2"
                value="<%= checklist_done %>" max="<%= checklist_total %>"></progress>

      <ul class="mt-3 grid gap-1 sm:grid-cols-2">
        <% checklist_keys.each do |key| %>
          <li>
            <%= form_with url: admin_homologation_request_document_checklist_path(hr),
                          method: :patch,
                          scope: :document_checklist,
                          data: { controller: "auto-submit" },
                          class: "flex items-center gap-2 py-1" do |f| %>
              <%= f.hidden_field :key, value: key %>
              <%= f.hidden_field :value, value: (hr.checklist_done?(key) ? "0" : "1") %>
              <input type="checkbox" class="checkbox checkbox-sm"
                     <%= "checked" if hr.checklist_done?(key) %>
                     data-action="auto-submit#submit">
              <span class="text-sm <%= 'line-through opacity-50' if hr.checklist_done?(key) %>">
                <%= t("requests.checklist.#{key}") %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <%# PIPELINE NOTES %>
  <% if hr.pipeline_notes.present? %>
    <div class="card bg-white border border-gray-200 md:col-span-2">
      <div class="card-body">
        <h3 class="text-sm font-semibold uppercase tracking-wide opacity-60"><%= t("admin.requests.sections.pipeline_notes") %></h3>
        <div class="text-sm whitespace-pre-wrap leading-relaxed mt-2"><%= hr.pipeline_notes %></div>
      </div>
    </div>
  <% end %>

</div>
