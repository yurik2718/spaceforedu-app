<% content_for :title, t("registrations.title") %>

<%= render "shared/page_header", title: t("registrations.title") %>

<%= form_with model: @user, url: registration_path, class: "card bg-base-100 shadow max-w-md mx-auto" do |f| %>
  <div class="card-body">
    <% if @user.errors.any? %>
      <div class="alert alert-error mb-4">
        <ul>
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-control mb-3">
      <%= f.label :name, class: "label" %>
      <%= f.text_field :name, class: "input input-bordered w-full", required: true %>
    </div>

    <div class="form-control mb-3">
      <%= f.label :email_address, class: "label" %>
      <%= f.email_field :email_address, class: "input input-bordered w-full", required: true %>
    </div>

    <div class="form-control mb-3">
      <%= f.label :password, class: "label" %>
      <%= f.password_field :password, class: "input input-bordered w-full", required: true %>
    </div>

    <div class="form-control mb-3">
      <%= f.label :password_confirmation, class: "label" %>
      <%= f.password_field :password_confirmation, class: "input input-bordered w-full", required: true %>
    </div>

    <div class="form-control mb-4">
      <label class="label cursor-pointer justify-start gap-2">
        <%= f.check_box :privacy_accepted, { class: "checkbox" }, "1", "0" %>
        <span><%= t("registrations.privacy_accept") %></span>
      </label>
    </div>

    <%= f.submit t("registrations.submit"), class: "btn btn-primary w-full" %>

    <p class="text-sm text-center mt-4">
      <%= t("registrations.have_account") %>
      <%= link_to t("nav.sign_in", default: "Sign in"), new_session_path, class: "link" %>
    </p>
  </div>
<% end %>
