<%# Two-line tagline + lede.
    Responsive sizes work in both contexts because each consumer is shown
    only at one breakpoint range (mobile-only block vs desktop-only panel). %>
<div class="space-y-3 lg:space-y-5">
  <h2 class="font-display font-bold text-3xl lg:text-4xl xl:text-5xl leading-[1.05] tracking-tight">
    <span class="text-primary"><%= t("auth.brand.tagline_line_1") %></span><br>
    <span class="text-ink"><%= t("auth.brand.tagline_line_2") %></span>
  </h2>
  <p class="text-sm text-mute lg:text-base lg:text-body max-w-md leading-relaxed">
    <%= t("auth.brand.lede") %>
  </p>
</div>
