<% content_for :title, @user.name %>

<%= render "shared/page_header",
      title: @user.name,
      actions: capture {
        concat link_to(t("actions.edit"), edit_profile_path, class: "btn btn-secondary btn-sm")
      } %>

<div class="space-y-6">

  <div class="grid gap-6 md:grid-cols-2">

    <%# ACCOUNT — identity card %>
    <div class="card bg-canvas border border-hairline-soft">
      <div class="card-body" style="--card-body-pad: 1.5rem">
        <div class="flex items-center gap-4">
          <%= render "shared/avatar", user: @user, size: :lg %>
          <div class="min-w-0">
            <p class="font-semibold text-lg text-ink truncate"><%= @user.name %></p>
            <p class="text-sm text-mute truncate"><%= @user.email_address %></p>
          </div>
        </div>

        <hr class="border-hairline-soft my-2">

        <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2.5 text-sm">
          <dt class="text-mute"><%= t("profile.fields.country") %></dt>
          <dd class="text-ink"><%= @user.country.present? ? t("profile.countries.#{@user.country}", default: @user.country) : "—" %></dd>

          <dt class="text-mute"><%= t("profile.fields.birthday") %></dt>
          <dd class="text-ink"><%= @user.birthday ? l(@user.birthday, format: :long) : "—" %></dd>

          <dt class="text-mute"><%= t("profile.fields.phone") %></dt>
          <dd class="text-ink"><%= masked_phone(@user.phone) %></dd>

          <dt class="text-mute"><%= t("profile.fields.locale") %></dt>
          <dd class="text-ink"><%= t("profile.locales.#{@user.locale}", default: @user.locale) %></dd>

          <% if @user.privacy_accepted_at %>
            <dt class="text-mute"><%= t("profile.show.conditions") %></dt>
            <dd class="text-ink flex items-center gap-1.5">
              <%= heroicon "check-circle", options: { class: "w-4 h-4 text-success shrink-0", "aria-hidden": true } %>
              <span><%= t("profile.show.conditions_accepted") %></span>
            </dd>
          <% end %>
        </dl>
      </div>
    </div>

    <%# NOTIFICATIONS — compact toggle rows %>
    <div class="card bg-canvas border border-hairline-soft">
      <div class="card-body" style="--card-body-pad: 1.5rem">
        <h3 class="text-base font-semibold text-ink"><%= t("profile.sections.notifications") %></h3>

        <div class="mt-2 divide-y divide-hairline-soft">
          <div class="flex items-center gap-3 py-2.5">
            <%= heroicon "envelope", options: { class: "w-4 h-4 text-ash shrink-0", "aria-hidden": true } %>
            <span class="flex-1 text-sm text-body"><%= t("profile.fields.notification_email") %></span>
            <span class="badge <%= @user.notification_email ? 'badge-success' : 'badge-ghost' %> badge-sm">
              <%= t(@user.notification_email ? "profile.toggle.on" : "profile.toggle.off") %>
            </span>
          </div>

          <div class="flex items-center gap-3 py-2.5">
            <%= heroicon "paper-airplane", options: { class: "w-4 h-4 text-ash shrink-0", "aria-hidden": true } %>
            <span class="flex-1 text-sm text-body"><%= t("profile.fields.notification_telegram") %></span>
            <span class="badge <%= @user.notification_telegram ? 'badge-success' : 'badge-ghost' %> badge-sm">
              <%= t(@user.notification_telegram ? "profile.toggle.on" : "profile.toggle.off") %>
            </span>
          </div>
        </div>
      </div>
    </div>

  </div>

  <%# GUARDIAN — only for minors %>
  <% if @user.is_minor %>
    <div class="card bg-canvas border border-hairline-soft">
      <div class="card-body" style="--card-body-pad: 1.5rem">
        <h3 class="text-base font-semibold text-ink"><%= t("profile.sections.guardian") %></h3>

        <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2.5 text-sm mt-2">
          <dt class="text-mute"><%= t("profile.fields.guardian_name") %></dt>
          <dd class="text-ink"><%= @user.guardian_name.presence || "—" %></dd>

          <dt class="text-mute"><%= t("profile.fields.guardian_email") %></dt>
          <dd class="text-ink"><%= @user.guardian_email.presence || "—" %></dd>

          <dt class="text-mute"><%= t("profile.fields.guardian_phone") %></dt>
          <dd class="text-ink"><%= masked_phone(@user.guardian_phone) %></dd>
        </dl>
      </div>
    </div>
  <% end %>

  <%# GDPR — visually separated danger zone %>
  <div class="border-t border-hairline-soft pt-6">
    <p class="text-xs font-semibold text-mute uppercase tracking-wider mb-4"><%= t("profile.gdpr.title") %></p>

    <% if @user.deletion_requested_at? %>
      <div class="alert alert-warning text-sm">
        <%= t("profile.gdpr.deletion_requested_notice", date: l(@user.deletion_requested_at, format: :long)) %>
      </div>
    <% else %>
      <div class="flex flex-col sm:flex-row gap-4">

        <div class="rounded-xl border border-hairline-soft p-4 space-y-2">
          <p class="font-medium text-sm text-ink"><%= t("profile.gdpr.export_button") %></p>
          <p class="text-xs text-mute leading-relaxed"><%= t("profile.gdpr.export_hint") %></p>
          <%= link_to t("profile.gdpr.export_button"), export_profile_path, class: "btn btn-sm btn-secondary" %>
        </div>

        <% if @user.student? %>
          <div class="rounded-xl border border-error/20 bg-error/5 p-4 space-y-2">
            <p class="font-medium text-sm text-error"><%= t("profile.gdpr.deletion_button") %></p>
            <p class="text-xs text-mute leading-relaxed"><%= t("profile.gdpr.deletion_hint") %></p>
            <%= button_to t("profile.gdpr.deletion_button"),
                          profile_deletion_path,
                          data:   { turbo_confirm: t("profile.gdpr.deletion_confirm") },
                          class:  "btn btn-sm btn-error btn-outline" %>
          </div>
        <% end %>

      </div>
    <% end %>
  </div>

</div>
