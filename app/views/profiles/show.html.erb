<% content_for :title, @user.name %>

<%= render "shared/page_header",
      title: @user.name,
      actions: capture {
        concat link_to(t("actions.edit"), edit_profile_path, class: "btn btn-ghost btn-sm")
      } %>

<div class="grid gap-6 md:grid-cols-2">

  <%# ACCOUNT — vCard style %>
  <div class="card bg-white shadow">
    <div class="card-body">
      <h3 class="card-title text-base"><%= t("profile.sections.account") %></h3>

      <div class="flex items-center gap-3 mt-2">
        <%= render "shared/avatar", user: @user, size: :lg %>
        <div class="min-w-0">
          <p class="font-semibold truncate text-ink"><%= @user.name %></p>
          <p class="text-sm text-mute truncate"><%= @user.email_address %></p>
        </div>
      </div>

      <div class="divider my-2"></div>

      <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm">
        <dt class="opacity-60"><%= t("profile.fields.country") %></dt>
        <dd><%= @user.country.present? ? t("profile.countries.#{@user.country}", default: @user.country) : "—" %></dd>

        <dt class="opacity-60"><%= t("profile.fields.birthday") %></dt>
        <dd><%= @user.birthday ? l(@user.birthday, format: :long) : "—" %></dd>

        <dt class="opacity-60"><%= t("profile.fields.phone") %></dt>
        <dd><%= masked_phone(@user.phone) %></dd>

        <dt class="opacity-60"><%= t("profile.fields.locale") %></dt>
        <dd><%= t("profile.locales.#{@user.locale}", default: @user.locale) %></dd>

        <dt class="opacity-60"><%= t("profile.fields.privacy_accepted_at") %></dt>
        <dd><%= @user.privacy_accepted_at ? l(@user.privacy_accepted_at, format: :long) : "—" %></dd>
      </dl>
    </div>
  </div>

  <%# NOTIFICATIONS %>
  <div class="card bg-white shadow">
    <div class="card-body">
      <h3 class="card-title text-base"><%= t("profile.sections.notifications") %></h3>

      <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm mt-2">
        <dt class="opacity-60"><%= t("profile.fields.notification_email") %></dt>
        <dd>
          <span class="badge <%= @user.notification_email ? 'badge-success' : 'badge-ghost' %> badge-sm">
            <%= t(@user.notification_email ? "profile.toggle.on" : "profile.toggle.off") %>
          </span>
        </dd>

        <dt class="opacity-60"><%= t("profile.fields.notification_telegram") %></dt>
        <dd>
          <span class="badge <%= @user.notification_telegram ? 'badge-success' : 'badge-ghost' %> badge-sm">
            <%= t(@user.notification_telegram ? "profile.toggle.on" : "profile.toggle.off") %>
          </span>
        </dd>
      </dl>
    </div>
  </div>

  <%# GUARDIAN — only for minors %>
  <% if @user.is_minor %>
    <div class="card bg-white shadow md:col-span-2">
      <div class="card-body">
        <h3 class="card-title text-base"><%= t("profile.sections.guardian") %></h3>

        <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm mt-2">
          <dt class="opacity-60"><%= t("profile.fields.guardian_name") %></dt>
          <dd><%= @user.guardian_name.presence || "—" %></dd>

          <dt class="opacity-60"><%= t("profile.fields.guardian_email") %></dt>
          <dd><%= @user.guardian_email.presence || "—" %></dd>

          <dt class="opacity-60"><%= t("profile.fields.guardian_phone") %></dt>
          <dd><%= masked_phone(@user.guardian_phone) %></dd>
        </dl>
      </div>
    </div>
  <% end %>

  <%# GDPR — Export & Deletion %>
  <div class="card bg-white shadow md:col-span-2">
    <div class="card-body">
      <h3 class="card-title text-base"><%= t("profile.gdpr.title") %></h3>

      <% if @user.deletion_requested_at? %>
        <div class="alert alert-warning text-sm mt-2">
          <%= t("profile.gdpr.deletion_requested_notice", date: l(@user.deletion_requested_at, format: :long)) %>
        </div>
      <% else %>
        <div class="flex flex-col sm:flex-row gap-4 mt-2">

          <div class="flex-1 rounded-xl border border-hairline-soft p-4 space-y-2">
            <p class="font-medium text-sm text-ink"><%= t("profile.gdpr.export_button") %></p>
            <p class="text-xs text-mute"><%= t("profile.gdpr.export_hint") %></p>
            <%= link_to t("profile.gdpr.export_button"), export_profile_path, class: "btn btn-sm btn-outline" %>
          </div>

          <% if @user.student? %>
            <div class="flex-1 rounded-xl border border-error/20 bg-error/5 p-4 space-y-2">
              <p class="font-medium text-sm text-error"><%= t("profile.gdpr.deletion_button") %></p>
              <p class="text-xs text-mute"><%= t("profile.gdpr.deletion_hint") %></p>
              <%= button_to t("profile.gdpr.deletion_button"),
                            profile_deletion_path,
                            data:   { turbo_confirm: t("profile.gdpr.deletion_confirm") },
                            class:  "btn btn-sm btn-error btn-outline" %>
            </div>
          <% end %>

        </div>
      <% end %>
    </div>
  </div>

</div>
