<%# Locals:
      conversation — Conversation
      hr           — HomologationRequest (conversation.homologation_request) %>
<%
  vars = {
    student: conversation.student.name,
    subject: hr.subject,
    plan:    hr.plan.title,
    amount:  format_eur(hr.plan.amount)
  }
  categories = QuickReply.categories(locale: I18n.locale)
%>
<% if categories.any? %>
  <div class="border-t border-hairline-soft px-3 py-2 bg-surface-soft/40">
    <div class="flex flex-wrap items-center gap-1.5">
      <span class="text-[11px] uppercase tracking-wide text-mute font-semibold mr-1 shrink-0">
        <%= t("admin.quick_replies.label") %>
      </span>
      <% categories.each do |cat| %>
        <% cat[:items].each do |reply| %>
          <button type="button"
                  data-action="quick-replies#insert"
                  data-body="<%= reply.render(vars) %>"
                  title="<%= cat[:label] %>"
                  class="inline-flex items-center text-xs px-2.5 py-1 rounded-full border border-hairline-soft bg-canvas text-body hover:border-ink hover:text-ink hover:bg-surface-card transition-colors">
            <%= reply.label %>
          </button>
        <% end %>
        <span aria-hidden="true" class="text-ash mx-1 last:hidden">·</span>
      <% end %>
    </div>
  </div>
<% end %>
