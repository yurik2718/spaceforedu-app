<nav class="navbar bg-base-100 shadow-sm">
  <div class="navbar-start">
    <%= link_to "Homologation", root_path, class: "btn btn-ghost text-lg font-semibold" %>
  </div>

  <% if current_user %>
    <div class="navbar-center hidden lg:flex">
      <ul class="menu menu-horizontal gap-1 px-1">
        <% if current_user.super_admin? %>
          <li><%= link_to t("nav.dashboard"),     dashboard_path,  class: nav_link_class("dashboard") %></li>
          <li><%= link_to t("nav.requests"),      requests_path,   class: nav_link_class("requests") %></li>
          <li><%= link_to t("nav.conversations"), conversations_path, class: nav_link_class("conversations") %></li>
        <% else %>
          <li><%= link_to t("nav.requests"),      requests_path,   class: nav_link_class("requests") %></li>
          <li><%= link_to t("nav.conversations"), conversations_path, class: nav_link_class("conversations") %></li>
        <% end %>
      </ul>
    </div>

    <div class="navbar-end gap-2">
      <div class="dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar placeholder">
          <div class="bg-primary text-primary-content w-9 rounded-full">
            <span class="text-sm"><%= current_user.initials %></span>
          </div>
        </div>
        <ul tabindex="0" class="menu dropdown-content bg-base-100 rounded-box z-10 mt-3 w-52 p-2 shadow">
          <li><%= link_to t("nav.profile"), profile_path %></li>
          <li><%= button_to t("nav.sign_out"), session_path, method: :delete, class: "w-full text-left" %></li>
        </ul>
      </div>
    </div>
  <% end %>
</nav>
