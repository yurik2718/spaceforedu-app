<nav class="flex items-center gap-[14px] h-14 px-5 bg-canvas border-b border-hairline-soft shrink-0">
  <%= link_to root_path, class: "flex items-center gap-2 font-display font-bold text-[18px] text-ink no-underline" do %>
    <span class="w-7 h-7 rounded-full bg-primary inline-flex items-center justify-center text-on-primary shrink-0">
      <svg viewBox="0 0 16 16" class="w-4 h-4" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M8 1.5C10 3.5 11 6 11 9v2H5V9c0-3 1-5.5 3-7.5z"/>
        <path d="M5 10L3.2 12.5 5 12z"/>
        <path d="M11 10l1.8 2.5L11 12z"/>
        <path d="M6.5 12L8 14.5 9.5 12z" opacity="0.65"/>
        <circle cx="8" cy="6.2" r="1.1" fill="#E8453C"/>
      </svg>
    </span>
    <span>Space for Edu</span>
  <% end %>

  <div class="flex gap-[6px] ml-[14px]">
    <% if current_user&.super_admin? %>
      <%= link_to t("nav.pipeline"), admin_pipeline_path,
            class: "nav-pill #{'nav-pill-active' if nav_link_class('admin/pipeline') == 'active'}" %>
    <% elsif current_user&.student? %>
      <%= link_to t("nav.my_requests"), root_path,
            class: "nav-pill #{'nav-pill-active' if nav_link_class('') == 'active'}" %>
      <%= link_to t("nav.new_request"), new_homologation_request_path,
            class: "nav-pill #{'nav-pill-active' if nav_link_class('homologation_requests/new') == 'active'}" %>
    <% end %>
  </div>

  <div class="flex-1"></div>

  <% if current_user %>
    <div class="flex items-center gap-2">
      <%= turbo_stream_from current_user %>

      <%= render "layouts/locale_switcher" %>

      <%= link_to notifications_path,
            class: "relative inline-flex items-center justify-center w-9 h-9 rounded-full bg-surface-card text-ink hover:bg-secondary-bg transition-colors",
            aria: { label: t("nav.notifications") } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M15 17h5l-1.4-1.4A2 2 0 0118 14.2V11a6 6 0 10-12 0v3.2a2 2 0 01-.6 1.4L4 17h5m6 0a3 3 0 11-6 0"/>
        </svg>
        <% unread_count = current_user.notifications.unread.count %>
        <% if unread_count > 0 %>
          <span class="absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 rounded-full bg-primary text-on-primary text-[11px] font-bold inline-flex items-center justify-center">
            <%= unread_count %>
          </span>
        <% end %>
      <% end %>

      <div class="dropdown dropdown-end relative" data-controller="dropdown">
        <button type="button"
                data-action="click->dropdown#toggle"
                class="inline-flex items-center gap-1.5 h-9 pl-1 pr-2.5 rounded-full bg-surface-card hover:bg-secondary-bg transition-colors cursor-pointer"
                aria-label="<%= t("nav.profile") %>"
                aria-haspopup="menu">
          <%= render "shared/avatar", user: current_user, size: :xs %>
          <svg class="w-3.5 h-3.5 text-mute" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.3 7.3a1 1 0 011.4 0L10 10.6l3.3-3.3a1 1 0 111.4 1.4l-4 4a1 1 0 01-1.4 0l-4-4a1 1 0 010-1.4z" clip-rule="evenodd"/>
          </svg>
        </button>
        <ul role="menu"
            class="dropdown-content absolute right-0 mt-2 w-52 p-2 bg-canvas rounded-2xl shadow-[0_16px_32px_rgba(0,0,0,0.18),0_2px_6px_rgba(0,0,0,0.10)] border border-hairline-soft z-30">
          <li role="none"><%= link_to t("nav.profile"), profile_path, role: "menuitem", class: "block px-3 py-2 rounded-lg hover:bg-surface-card text-body text-sm no-underline" %></li>
          <li role="none" class="my-1 border-t border-hairline-soft"></li>
          <li role="none"><%= button_to t("nav.sign_out"), session_path, method: :delete, class: "w-full text-left px-3 py-2 rounded-lg hover:bg-surface-card text-body text-sm" %></li>
        </ul>
      </div>
    </div>
  <% else %>
    <div class="flex items-center gap-2">
      <%= render "layouts/locale_switcher" %>
      <%= link_to t("nav.sign_in"), new_session_path, class: "nav-pill" %>
      <%= link_to t("registrations.submit"), new_registration_path, class: "btn btn-primary h-9" %>
    </div>
  <% end %>
</nav>
