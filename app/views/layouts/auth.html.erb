<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
  <head>
    <title><%= content_for(:title) || "Space for Edu" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <meta name="theme-color" content="#E8453C">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="h-full bg-canvas text-body antialiased font-sans">
    <main class="min-h-screen flex">
      <%# Form column — narrower than the brand panel to give the panel visual dominance %>
      <section class="flex-1 lg:flex-none lg:w-[44%] xl:w-[40%] flex flex-col px-6 sm:px-12 lg:px-14 xl:px-16 py-8 lg:py-10">
        <header class="flex items-center justify-between">
          <%= link_to root_path, class: "flex items-center gap-2 font-display font-bold text-lg text-ink no-underline" do %>
            <span class="w-7 h-7 rounded-full bg-primary inline-flex items-center justify-center text-on-primary shrink-0">
              <svg viewBox="0 0 16 16" class="w-4 h-4" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M8 1.5C10 3.5 11 6 11 9v2H5V9c0-3 1-5.5 3-7.5z"/>
                <path d="M5 10L3.2 12.5 5 12z"/>
                <path d="M11 10l1.8 2.5L11 12z"/>
                <path d="M6.5 12L8 14.5 9.5 12z" opacity="0.65"/>
                <circle cx="8" cy="6.2" r="1.1" fill="#E8453C"/>
              </svg>
            </span>
            <span>Space for Edu</span>
          <% end %>

          <%= render "layouts/locale_switcher" %>
        </header>

        <%# Mobile-only condensed brand intro — desktop sees the full panel on the right %>
        <div class="lg:hidden mt-10 max-w-sm space-y-4">
          <%= render "auth/eyebrow" %>
          <%= render "auth/tagline" %>
        </div>

        <div class="flex-1 flex items-center justify-center py-10 lg:py-8">
          <div class="w-full max-w-sm space-y-7">
            <% if flash.any? %>
              <div class="space-y-2">
                <% flash.each do |type, message| %>
                  <div class="alert <%= flash_alert_class(type) %>">
                    <span><%= message %></span>
                  </div>
                <% end %>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </div>

        <footer class="text-xs text-ash text-center sm:text-left space-y-1">
          <p>© <%= Date.current.year %> Space for Edu — <%= brand_location %></p>
          <p class="flex flex-wrap justify-center sm:justify-start gap-x-2 gap-y-1">
            <%= mail_to support_email, class: "hover:text-ink no-underline" %>
            <span aria-hidden="true">·</span>
            <%= link_to "WhatsApp #{support_whatsapp}", support_whatsapp_url,
                  target: "_blank", rel: "noopener", class: "hover:text-ink no-underline" %>
            <span aria-hidden="true">·</span>
            <%= link_to t("nav.privacy"), privacy_path, class: "hover:text-ink no-underline" %>
          </p>
        </footer>
      </section>

      <%# Brand panel (hidden on small screens) — takes the dominant width %>
      <aside class="hidden lg:flex lg:flex-1 bg-surface-card border-l border-hairline-soft px-12 xl:px-20 py-10 lg:py-12 flex-col relative overflow-hidden">
        <%= render "auth/brand_panel" %>
      </aside>
    </main>
    <%= render "shared/cookie_notice" %>
  </body>
</html>
