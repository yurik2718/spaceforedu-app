<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
  <head>
    <title><%= content_for(:title) || "Space for Edu" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <meta name="theme-color" content="#E8453C">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="h-full bg-canvas text-body antialiased font-sans">
    <main class="min-h-screen flex">
      <%# Form column — narrower than the brand panel to give the panel visual dominance %>
      <section class="flex-1 lg:flex-none lg:w-[44%] xl:w-[40%] flex flex-col px-6 sm:px-12 lg:px-14 xl:px-16 py-8 lg:py-10">
        <header class="flex items-center justify-between">
          <%= render "shared/brand_logo" %>

          <%= render "layouts/locale_switcher" %>
        </header>

        <div class="flex-1 flex items-center justify-center py-10 lg:py-8">
          <div class="w-full max-w-sm space-y-7">
            <% if flash.any? %>
              <div class="space-y-2">
                <% flash.each do |type, message| %>
                  <div class="alert <%= flash_alert_class(type) %>">
                    <span><%= message %></span>
                  </div>
                <% end %>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </div>

        <footer class="text-xs text-ash text-center sm:text-left">
          <p>© <%= Date.current.year %> Space for Edu · <%= link_to t("nav.privacy"), privacy_path, class: "hover:text-ink no-underline" %></p>
        </footer>
      </section>

      <%# Brand panel (hidden on small screens) — takes the dominant width %>
      <aside class="hidden lg:flex lg:flex-1 bg-surface-card border-l border-hairline-soft px-12 xl:px-20 py-10 lg:py-12 flex-col relative overflow-hidden">
        <%= render "auth/brand_panel" %>
      </aside>
    </main>
    <%= render "shared/cookie_notice" %>
  </body>
</html>
